---
import "../styles/global.css";
---

<div class="h-screen flex flex-col bg-[#f5f1e8]">
  <!-- HEADER -->
  <div
    class="h-14 border-b flex items-center justify-between px-6 bg-[#efe9dc]"
  >
    <div class="flex items-center gap-2">
      <div class="flex gap-2">
        <div class="w-3 h-3 rounded-full bg-red-400"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
        <div class="w-3 h-3 rounded-full bg-green-400"></div>
      </div>
    </div>

    <div class="text-center leading-tight">
      <p class="font-semibold">Notas</p>
      <p class="text-xs text-gray-500" id="username"></p>
    </div>

    <div class="flex items-center gap-4">
      <button
        id="newNoteBtn"
        class="w-8 h-8 flex items-center justify-center rounded-full border hover:bg-gray-200 transition"
      >
        +
      </button>
      <button id="logoutBtn" class="text-sm text-gray-600 hover:underline"
        >Logout</button
      >
    </div>
  </div>

  <!-- MAIN -->
  <div class="flex flex-1 min-h-0">
    <!-- SIDEBAR -->
    <aside class="w-1/3 max-w-sm border-r p-6 overflow-y-auto">
      <input
        id="searchInput"
        placeholder="Buscar notas..."
        class="w-full mb-4 px-3 py-2 rounded-lg border bg-white outline-none"
      />

      <div id="notesList" class="space-y-4"></div>
    </aside>

    <!-- EDITOR -->
    <section class="flex-1 p-8 flex flex-col min-h-0">
      <div class="flex justify-between items-center mb-4">
        <input
          id="titleInput"
          placeholder="Nueva nota"
          class="text-2xl font-semibold bg-transparent outline-none w-full"
        />
        <button
          id="deleteBtn"
          class="px-3 py-1 rounded-lg border text-red-500 hover:bg-red-50 transition"
        >
          Eliminar
        </button>
      </div>

      <textarea
        id="contentInput"
        placeholder="Escribe algo..."
        class="w-full flex-1 outline-none resize-none bg-transparent"
      ></textarea>

      <p id="status" class="text-xs text-gray-400 mt-2"></p>
    </section>
  </div>
  class="px-3 py-1 rounded-lg border text-red-500 hover:bg-red-50 transition cursor-pointer"
</div>

<script type="module">
  import { supabase } from "/src/lib/supabase.ts";

  // -------- estado ----------
  let notes = [];
  let selectedNoteId = null;
  let saveTimer = null;

  // -------- elementos ----------
  const usernameEl = document.getElementById("username");
  const notesList = document.getElementById("notesList");
  const titleInput = document.getElementById("titleInput");
  const contentInput = document.getElementById("contentInput");
  const newNoteBtn = document.getElementById("newNoteBtn");
  const deleteBtn = document.getElementById("deleteBtn");
  const logoutBtn = document.getElementById("logoutBtn");
  const statusEl = document.getElementById("status");
  const searchInput = document.getElementById("searchInput");

  // -------- auth ----------
  const {
    data: { user },
  } = await supabase.auth.getUser();
  if (!user) window.location.href = "/login";
  usernameEl.textContent = user.email;

  logoutBtn.addEventListener("click", async () => {
    await supabase.auth.signOut();
    window.location.href = "/";
  });

  // -------- cargar notas ----------
  async function loadNotes() {
    const { data, error } = await supabase
      .from("notes")
      .select("*")
      .order("created_at", { ascending: false });

    if (error) {
      console.error(error);
      return;
    }

    notes = data ?? [];
    renderSidebar();

    if (notes.length && !selectedNoteId) {
      openNote(notes[0].id);
    } else if (!notes.length) {
      // estado vacío
      titleInput.value = "";
      contentInput.value = "";
      titleInput.placeholder = "Nueva nota";
      contentInput.placeholder = "Escribe algo...";
      statusEl.textContent = "No hay notas aún";
    }
  }

  // -------- sidebar ----------
  function renderSidebar(list = notes) {
    notesList.innerHTML = "";

    list.forEach((note) => {
      const card = document.createElement("div");
      card.className =
        "rounded-xl p-4 shadow cursor-pointer transition " +
        (note.id === selectedNoteId
          ? "bg-yellow-200"
          : "bg-white hover:bg-yellow-100");

      const title = document.createElement("h3");
      title.className = "font-semibold";
      title.textContent = note.title || "Sin título";

      const preview = document.createElement("p");
      preview.className = "text-sm text-gray-600 line-clamp-2";
      preview.textContent = note.content || "Sin contenido";

      const time = document.createElement("p");
      time.className = "text-xs text-gray-400";
      time.textContent = timeAgo(note.created_at);

      card.appendChild(title);
      card.appendChild(preview);
      card.appendChild(time);

      card.addEventListener("click", () => openNote(note.id));

      notesList.appendChild(card);
    });
  }

  function openNote(id) {
    selectedNoteId = id;
    const note = notes.find((n) => n.id === id);
    if (!note) return;

    titleInput.value = note.title ?? "";
    contentInput.value = note.content ?? "";
    statusEl.textContent = "Editando";

    renderSidebar();
  }

  // -------- crear nota ----------
  newNoteBtn.addEventListener("click", async () => {
    const { data, error } = await supabase
      .from("notes")
      .insert({
        title: "Nueva nota",
        content: "",
        user_id: user.id,
      })
      .select()
      .single();

    if (error) {
      alert(error.message);
      return;
    }

    notes.unshift(data);
    openNote(data.id);
    renderSidebar();
    statusEl.textContent = "Nota creada";
  });

  // -------- borrar nota ----------
  deleteBtn.addEventListener("click", async () => {
    if (!selectedNoteId) return;

    const confirmDelete = confirm("Eliminar esta nota?");

    if (!confirmDelete) return;

    await supabase.from("notes").delete().eq("id", selectedNoteId);

    notes = notes.filter((n) => n.id !== selectedNoteId);
    selectedNoteId = null;

    await loadNotes();
  });

  searchInput.addEventListener("input", () => {
    const query = searchInput.value.toLowerCase();

    const filtered = notes.filter(
      (note) =>
        note.title?.toLowerCase().includes(query) ||
        note.content?.toLowerCase().includes(query),
    );

    renderSidebar(filtered);
  });

  // -------- auto-guardar ----------
  function scheduleSave() {
    if (!selectedNoteId) return;

    clearTimeout(saveTimer);
    saveTimer = setTimeout(async () => {
      statusEl.innerHTML = "Guardando <span class='animate-pulse'>...</span>";
      const title = titleInput.value;
      const content = contentInput.value;

      const { error } = await supabase
        .from("notes")
        .update({ title, content })
        .eq("id", selectedNoteId);

      if (!error) {
        const idx = notes.findIndex((n) => n.id === selectedNoteId);
        if (idx !== -1) {
          notes[idx].title = title;
          notes[idx].content = content;
        }
        renderSidebar();
        statusEl.textContent = "Guardado";
      } else {
        statusEl.textContent = "Error al guardar";
        console.error(error);
      }
    }, 600); // debounce
  }

  titleInput.addEventListener("input", scheduleSave);
  contentInput.addEventListener("input", scheduleSave);

  // -------- util ----------
  function timeAgo(date) {
    const d = new Date(date + "Z");
    const now = new Date();

    const isToday = d.toDateString() === now.toDateString();

    const yesterday = new Date();
    yesterday.setDate(now.getDate() - 1);

    const isYesterday = d.toDateString() === yesterday.toDateString();

    const time = d.toLocaleTimeString([], {
      hour: "2-digit",
      minute: "2-digit",
    });

    if (isToday) return time;

    if (isYesterday) return "Yesterday " + time;

    return (
      d.toLocaleDateString([], {
        day: "numeric",
        month: "short",
      }) +
      " " +
      time
    );
  }

  // -------- init ----------
  await loadNotes();
</script>
