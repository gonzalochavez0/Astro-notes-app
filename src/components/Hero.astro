        <script>
      const navbar = document.getElementById("navbar");

      if (navbar) {
        window.addEventListener("scroll", () => {
          if (window.scrollY > 40) {
            navbar.classList.add(
              "backdrop-blur-md",
              "bg-white/70",
              "shadow-sm",
              "border-b",
            );
          } else {
            navbar.classList.remove(
              "backdrop-blur-md",
              "bg-white/70",
              "shadow-sm",
              "border-b",
            );
          }
        });
      }
    </script>